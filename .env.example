# PI Agent Design School — Environment Variables
# Copy to .env.local and fill in values via Infisical or your secrets manager.
# NEVER commit real secrets to this file.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pi_agent_school

# Certificate signing (Infisical reference: /pi-agent-school/CERT_ISSUER_SECRET)
CERT_ISSUER_SECRET=change-me-in-production

# Admin authentication
ADMIN_SECRET=change-me-in-production

# Next.js
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Stripe (scaffold only — do not capture real payments in tests)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder

# Infisical (for production secret management)
INFISICAL_CLIENT_ID=
INFISICAL_CLIENT_SECRET=
INFISICAL_PROJECT_ID=
INFISICAL_ENVIRONMENT=dev

# External providers (mocked in tests)
OPENROUTER_API_KEY=
HUGGINGFACE_API_KEY=
REPLICATE_API_KEY=
POSTIZ_API_KEY=
PAPERCLIP_API_KEY=
